# ============================================================
# 影视影评分享系统 — 生产环境变量模板
# 部署到腾讯云 CloudBase 时，在控制台「服务设置 → 环境变量」中配置
# ============================================================

# Flask 密钥（务必修改为随机字符串）
SECRET_KEY=change-this-to-a-random-string-in-production

# ========== MySQL 数据库（CloudBase 云托管自动注入） ==========
# 以下变量由 CloudBase 云托管在绑定 MySQL 后自动注入，无需手动配置：
# MYSQL_ADDRESS=<自动>
# MYSQL_PORT=3306
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=<自动>
# MYSQL_DATABASE=movie_review

# ========== QQ 邮箱 SMTP（发验证码用） ==========
MAIL_USERNAME=your-qq-email@qq.com
MAIL_PASSWORD=your-smtp-authorization-code
